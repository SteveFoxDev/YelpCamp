<%- include("../partials/header") %>

  <div class="row">
    <h1 class="myForm-h1">Create a new campground</h1>
    <div class="myForm-div">
      <form action="/campgrounds" method="post">
        <div class="form-group">
          <input
            class="form-control"
            type="text"
            name="campground[name]"
            value="" placeholder="name">
        </div>
        <div class="form-group">
          <input
            class="form-control"
            type="number"
            name="campground[price]"
            min="0.00"
            step="0.01"
            placeholder="price">
        </div>
        <div class="form-group">
            <select
              class="form-control"
              type="text"
              name="campground[rate]"
              placeholder="Select One">
                <option value="Nightly">Nightly</option>
                <option value="Weekly">Weekly</option>
                <option value="Monthly">Monthly</option>
            </select>
        </div>
        <div class="form-group">
          <label for="campground[location]">Location</label>
          <input
            class="form-control"
            type="text"
            name="campground[location]" 
            id="location"
            placeholder="Yosemite National Park, CA">
        </div>
        <div class="form-group">
          <input
            class="form-control"
            type="text"
            name="campground[image]"
            value=""
            placeholder="image url">
        </div>
        <div class="form-group">
          <input
            class="form-control"
            type="text"
            name="campground[description]"
            value=""
            placeholder="description">
        </div>
        <div class="form-group">
          <button
            class="btn btn-lg btn-primary btn-block"
            type="submit"
            name="button">
            Submit
          </button>
        </div>
        <a href="/campgrounds">Go Back</a>
      </form>
    </div>

  </div>

<%- include("../partials/footer") %>
