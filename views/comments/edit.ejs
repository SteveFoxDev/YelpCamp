<%- include("../partials/header") %>

  <div class="row">
    <h1 class="myForm-h1">Edit Comment for <%= campground.name %> </h1>
    <div class="myForm-div">
      <form
        action="/campgrounds/<%= campground_id %>/comments/<%= comment._id %>?_method=PUT"
        method="post">
        <div class="form-group">
          <input
            class="form-control"
            type="text" name="comment[text]"
            value="<%= comment.text %>">
        </div>
        <div class="form-group">
          <button class="btn btn-lg btn-primary btn-block" type="submit">Submit</button>
        </div>
        <a href="/campgrounds/<%= campground._id %>">Go Back</a>
      </form>
    </div>

  </div>

<%- include("../partials/footer") %>
