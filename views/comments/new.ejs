<%- include("../partials/header") %>

  <div class="row">
    <h1 class="myForm-h1">Add New Comment to <%= campground.name %></h1>
    <div class="myForm-div">
      <form action="/campgrounds/<%= campground._id %>/comments" method="post">
        <div class="form-group">
          <input class="form-control" type="text" name="comment[text]" value="" placeholder="comment">
        </div>
        <div class="form-group">
          <button class="btn btn-lg btn-primary btn-block" type="submit" name="button">Submit</button>
        </div>
        <a href="/campgrounds/<%= campground._id %>">Go Back</a>
      </form>
    </div>

  </div>

<%- include("../partials/footer") %>
